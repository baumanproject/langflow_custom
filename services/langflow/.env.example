LANGFLOW_AUTO_LOGIN=true
LANGFLOW_COMPONENTS_PATH=/app/components
LANGFLOW_CONFIG_DIR=/tmp
LANGFLOW_SKIP_AUTH_AUTO_LOGIN=true
LANGFLOW_PORT=7860
LANGFLOW_HOST=0.0.0.0

# These variables are used by in-container component tests
TEST_MINIO_ENDPOINT_URL=http://minio:9000
TEST_MINIO_ACCESS_KEY=minio_s3_user
TEST_MINIO_SECRET_KEY=minio_s3_password
TEST_MINIO_BUCKET=langflow-s3-bucket
TEST_MINIO_REGION=us-east-1

# Optional Langflow API smoke tests
TEST_LANGFLOW_BASE_URL=http://localhost:7860
